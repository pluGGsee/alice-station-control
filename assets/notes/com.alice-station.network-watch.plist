<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.alice-station.network-watch</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/mac/.local/bin/alice-station-start.sh</string>
    </array>

    <!-- Запускать при изменении сетевых настроек macOS -->
    <key>WatchPaths</key>
    <array>
        <string>/var/run/resolv.conf</string>
    </array>

    <key>StandardOutPath</key>
    <string>/Users/mac/Library/Logs/alice-station-launchd.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/mac/Library/Logs/alice-station-launchd.log</string>

    <key>KeepAlive</key>
    <false/>
</dict>
</plist>
